<mxfile host="app.diagrams.net">
  <diagram name="全文技术路线图" id="paper-overview">
    <mxGraphModel dx="600" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===== Blue Section Frame: 数据获取与处理 ===== -->
        <mxCell id="2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#004c99;dashed=1;strokeWidth=2;fontFamily=Microsoft YaHei;" value="" vertex="1">
