        <mxCell id="4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#004c99;strokeWidth=2;dashed=1;fontFamily=Microsoft YaHei;fontSize=12;" value="&lt;b&gt;数据来源&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;UCI Bike Sharing&lt;br&gt;17,379条小时级数据&lt;br&gt;2011-2012年&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="180" x="70" y="120" as="geometry"/>
        </mxCell>
        <mxCell id="5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#004c99;strokeWidth=2;dashed=1;fontFamily=Microsoft YaHei;fontSize=12;" value="&lt;b&gt;数据清洗&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;readtable加载&lt;br&gt;异常检测&lt;br&gt;缺失值处理&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="180" x="290" y="120" as="geometry"/>
        </mxCell>
        <mxCell id="6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#004c99;strokeWidth=2;dashed=1;fontFamily=Microsoft YaHei;fontSize=12;" value="&lt;b&gt;特征工程&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;高峰时段标记&lt;br&gt;工作日/周末分类&lt;br&gt;datetime构建&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="180" x="510" y="120" as="geometry"/>
        </mxCell>
        <mxCell id="7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#004c99;strokeWidth=2;dashed=1;fontFamily=Microsoft YaHei;fontSize=12;" value="&lt;b&gt;探索性分析&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;热力图(潮汐效应)&lt;br&gt;时间序列总览&lt;br&gt;季节/周期分析&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="180" x="730" y="120" as="geometry"/>
        </mxCell>

        <!-- Arrows between blue items -->
        <mxCell id="b1" edge="1" parent="1" style="endArrow=classic;html=1;strokeWidth=2;fillColor=#dae8fc;strokeColor=#6c8ebf;" source="4" target="5">
