        <mxCell id="arrow_down1" edge="1" parent="1" style="endArrow=classic;html=1;strokeWidth=3;fillColor=#f8cecc;strokeColor=#b85450;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" source="8" target="11">
          <mxGeometry relative="1" as="geometry"/>
