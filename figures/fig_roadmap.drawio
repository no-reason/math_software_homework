        <mxCell id="16" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#00897b;dashed=1;fontFamily=Microsoft YaHei;fontSize=12;" value="&lt;b&gt;结果分析&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;• 潮汐效应定量确认(早8:00/晚17:00)&lt;br&gt;• 误差时段分解(高峰RMSE最高112.4)&lt;br&gt;• 排队容量建议(c=40最优)&lt;br&gt;• 与实际运营管理的结合&lt;/font&gt;" vertex="1">
          <mxGeometry height="130" width="400" x="70" y="710" as="geometry"/>
