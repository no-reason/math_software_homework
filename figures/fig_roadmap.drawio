        </mxCell>
        <mxCell id="3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=16;fontColor=#004c99;fontFamily=Microsoft YaHei;" value="&lt;b&gt;一、数据获取与预处理分析&lt;/b&gt;" vertex="1">
          <mxGeometry height="40" width="950" x="40" y="50" as="geometry"/>
