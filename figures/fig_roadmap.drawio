        <!-- ===== Pink Section Frame: 模型构建与求解 ===== -->
        <mxCell id="9" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#990000;dashed=1;strokeWidth=2;fontFamily=Microsoft YaHei;" value="" vertex="1">
          <mxGeometry height="260" width="950" x="40" y="400" as="geometry"/>
        </mxCell>
        <mxCell id="10" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=16;fontColor=#990000;fontFamily=Microsoft YaHei;" value="&lt;b&gt;二、模型构建与求解&lt;/b&gt;" vertex="1">
          <mxGeometry height="40" width="950" x="40" y="370" as="geometry"/>
        </mxCell>
        <mxCell id="11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#990000;strokeWidth=2;dashed=1;fontFamily=Microsoft YaHei;fontSize=12;" value="&lt;b&gt;子问题一：ARIMA时间序列&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;① ADF单位根检验→一阶差分&lt;br&gt;② ACF/PACF图定阶(p=2,q=2)&lt;br&gt;③ ARIMA(2,1,2)参数估计&lt;br&gt;④ Ljung-Box残差诊断&lt;br&gt;⑤ 未来24h滚动预测&lt;br&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="190" width="400" x="70" y="440" as="geometry"/>
        </mxCell>
        <mxCell id="12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#990000;strokeWidth=2;dashed=1;fontFamily=Microsoft YaHei;fontSize=12;" value="&lt;b&gt;子问题二：M/M/c排队论&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;① 参数设定：λ=40, μ=1.2&lt;br&gt;② 稳定性判断：ρ=λ/(cμ)&amp;lt;1&lt;br&gt;③ 计算P₀, Lq, Wq, ρ&lt;br&gt;④ 灵敏度分析：c=20→60&lt;br&gt;⑤ 最优容量区间推荐&lt;br&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="190" width="400" x="550" y="440" as="geometry"/>
        </mxCell>

        <!-- Arrow connecting ARIMA results to evaluation -->
        <mxCell id="arrow_arima_down" edge="1" parent="1" style="endArrow=classic;html=1;strokeWidth=2;fillColor=#f8cecc;strokeColor=#b85450;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;" source="11" target="15">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_queue_down" edge="1" parent="1" style="endArrow=classic;html=1;strokeWidth=2;fillColor=#f8cecc;strokeColor=#b85450;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;" source="12" target="15">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Pink section output -->
        <mxCell id="13" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#990000;dashed=1;fontFamily=Microsoft YaHei;fontSize=11;" value="&lt;b&gt;模型输出&lt;/b&gt;&lt;br&gt;ARIMA: RMSE=92.1, MAE=73.6&lt;br&gt;排队论: c* = 40~50" vertex="1">
          <mxGeometry height="60" width="250" x="385" y="580" as="geometry"/>
        </mxCell>

        <!-- Arrow from model output to evaluation -->
        <mxCell id="arrow_down2" edge="1" parent="1" style="endArrow=classic;html=1;strokeWidth=3;fillColor=#e1f5fe;strokeColor=#00897b;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" source="13" target="16">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

